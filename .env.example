DATABASE_URL=postgres://user:pass@host/db
# 여러 앱이 한 Postgres를 공유할 때 전용 스키마로 격리 (비우면 public 사용)
DB_SCHEMA=hyojin
SESSION_SECRET=change-me
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:you@example.com
# 메일: Render 무료플랜은 SMTP 포트를 막으므로 Resend(HTTPS API) 권장.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# SMTP는 RESEND_API_KEY 없을 때 폴백으로만 사용 (로컬 등)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
UNLOCK_EMAIL=
PORT=5173
